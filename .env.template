# .env 配置文件（模板）

# Telegram Bot Token（必需）
AUTORESEARCH_TELEGRAM_BOT_TOKEN=你的Bot Token

# API 配置
AUTORESEARCH_API_HOST=127.0.0.1
AUTORESEARCH_API_PORT=8001

# Cloudflare Tunnel URL（从 /tmp/cloudflared_8001.log 获取）
AUTORESEARCH_PANEL_BASE_URL=https://your-tunnel.trycloudflare.com

# Topic IDs（从 Telegram 群组获取）
# 格式：https://t.me/c/1234567890/2 → Topic ID = 2
AUTORESEARCH_TOPIC_MARKET=10
AUTORESEARCH_TOPIC_CREATIVE=20
AUTORESEARCH_TOPIC_AUDIT=99
AUTORESEARCH_TOPIC_TECH=30
AUTORESEARCH_TOPIC_BUSINESS=40

# Claude CLI 配置
AUTORESEARCH_CLAUDE_COMMAND=claude

# 管理员 Telegram UID（用于权限控制）
AUTORESEARCH_ADMIN_UIDS=<YOUR_TELEGRAM_UID>

# Telegram Secret Token（可选，用于 Webhook 验证）
AUTORESEARCH_TELEGRAM_SECRET_TOKEN=your-secret-token

# 面板访问控制
AUTORESEARCH_PANEL_JWT_SECRET=your-jwt-secret
AUTORESEARCH_PANEL_JWT_EXPIRATION_HOURS=24

# WebAuthn 配置（可选）
# AUTORESEARCH_WEBAUTHN_RP_ID=localhost
# AUTORESEARCH_WEBAUTHN_RP_NAME=Autonomous Agent Stack

# 环境标识
ENVIRONMENT=development

{
  "id": "software_change_agent_v0",
  "name": "Software Change Agent",
  "description": "Bounded code and product changes routed into the existing manager-agent pipeline.",
  "version": "0.1.0",
  "execution_backend": "manager_agent",
  "input_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "required": ["prompt"],
    "properties": {
      "prompt": {
        "type": "string",
        "minLength": 1,
        "description": "Natural-language change request"
      }
    }
  },
  "output_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "dispatch_id": {"type": "string"},
      "final_status": {"type": "string"},
      "summary": {"type": "string"}
    }
  },
  "required_capabilities": {
    "platform": ["linux", "openclaw"],
    "tools": ["patch_generation", "tests", "git"],
    "min_versions": {
      "openclaw": "0.1.0"
    }
  },
  "supported_worker_types": ["linux", "openclaw"],
  "governance": {
    "risk_level": "high",
    "approval_rules": {
      "requires_approval_for_write": true,
      "requires_approval_for_delete": true,
      "approval_threshold": 1
    },
    "permission_boundaries": {
      "max_execution_time_sec": 1800,
      "max_retry_count": 2
    }
  },
  "failure_handling": {
    "fallback_strategy": "manual"
  },
  "execution": {
    "timeout_ms": 1800000,
    "heartbeat_interval_ms": 10000,
    "checkpoint_enabled": true,
    "resource_limits": {
      "max_memory_mb": 2048,
      "max_cpu_percent": 90,
      "max_network_mb": 500
    }
  },
  "artifacts": {
    "required_artifacts": ["metadata"],
    "artifact_format": {
      "screenshots": "png",
      "logs": "json",
      "receipts": "json"
    },
    "retention_policy": {
      "keep_artifacts_for_hours": 168,
      "archive_to": null
    }
  },
  "observability": {
    "log_level": "info",
    "metrics_to_collect": ["success_rate", "execution_time_ms"],
    "custom_tags": {
      "domain": "software",
      "entrypoint": "housekeeper"
    }
  },
  "dependencies": {},
  "compatibility": {
    "min_compatible_version": "0.1.0"
  },
  "metadata": {
    "author": "Agent Control Plane Team",
    "license": "MIT",
    "tags": ["software", "code", "product", "manager"],
    "categories": ["engineering"],
    "limits": {
      "supported_scopes": [
        "small_page_change",
        "copy_or_config_edit",
        "small_bug_fix",
        "low_risk_scaffold"
      ],
      "unsupported_scopes": [
        "full_stack_feature",
        "large_refactor",
        "architecture_upgrade",
        "autonomous_pr_approval"
      ]
    }
  }
}

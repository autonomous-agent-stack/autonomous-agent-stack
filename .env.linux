# Linux primary-runtime overrides.
# Keep shared defaults in `.env.example`; source this file locally before `make doctor-linux` / `make start`.

AUTORESEARCH_RUNTIME_HOST=linux
AUTORESEARCH_EXECUTION_ROLE=primary
AUTORESEARCH_TASK_RISK_PROFILE=full
OPENHANDS_RUNTIME=host

AUTORESEARCH_API_HOST=0.0.0.0
AUTORESEARCH_API_PORT=8001
AUTORESEARCH_API_DB_PATH=artifacts/api/evaluations.sqlite3

AUTORESEARCH_UPSTREAM_WATCH_WORKSPACE_ROOT=artifacts/upstream-watch/workspace

# API 认证配置
AUTH_SECRET_KEY=your-secret-key-change-this-in-production
ADMIN_API_KEY=your-admin-api-key

# 允许的 Agent ID 列表（逗号分隔）
ALLOWED_AGENTS=agent-001,agent-002,agent-003

# Anthropic API Key（用于 Claude）
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI API Key（可选）
OPENAI_API_KEY=your-openai-api-key

# 数据库配置
DATABASE_URL=sqlite:///./data/autoresearch.db

# Telegram Bot Token（可选）
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# MCP 配置（可选）
MCP_SERVER_URL=http://localhost:3000

# GitHub assistant template
GH_ASSISTANT_BOT_ACCOUNT=your-bot-account
GH_ASSISTANT_WORKSPACE_ROOT=/tmp/github-assistant
GH_ASSISTANT_EXECUTOR_ADAPTER=codex
GH_ASSISTANT_EXECUTOR_BINARY=codex
# Optional: overrides executor.command from assistant.yaml
# GH_ASSISTANT_EXECUTOR=codex exec

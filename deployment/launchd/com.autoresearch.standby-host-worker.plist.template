<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.autoresearch.standby-host-worker</string>

  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON__</string>
    <string>__WORKDIR__/scripts/standby_host_worker.py</string>
    <string>--repo-root</string>
    <string>__WORKDIR__</string>
    <string>--host-id</string>
    <string>__HOST_ID__</string>
    <string>--poll-seconds</string>
    <string>5</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONPATH</key>
    <string>__WORKDIR__/src</string>
  </dict>

  <key>WorkingDirectory</key>
  <string>__WORKDIR__</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>__WORKDIR__/logs/standby-host-worker.log</string>

  <key>StandardErrorPath</key>
  <string>__WORKDIR__/logs/standby-host-worker.err.log</string>
</dict>
</plist>

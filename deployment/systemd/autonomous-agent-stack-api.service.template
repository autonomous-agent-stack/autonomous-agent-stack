[Unit]
Description=Autonomous Agent Stack API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
Group=__GROUP__
WorkingDirectory=__WORKDIR__
Environment=PYTHONUNBUFFERED=1
ExecStart=__WORKDIR__/scripts/run_api_service.sh
Restart=always
RestartSec=5
TimeoutStartSec=120

[Install]
WantedBy=multi-user.target

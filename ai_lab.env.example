# ai_lab environment configuration
# Copy to ai_lab.env and adjust if needed.

LAB_USER=ai_lab
LAB_FULLNAME="AI Lab"
WORKSPACE_DIR=/Users/ai_lab/workspace
LOG_DIR=/Users/ai_lab/logs
CACHE_DIR=/Users/ai_lab/.cache

# COMPOSE_DIR and COMPOSE_FILE default to <repo>/sandbox/ai-lab in launch_ai_lab.sh

AUTO_OPEN_DOCKER=1

# ===== Core runtime =====
AUTORESEARCH_API_HOST=127.0.0.1
AUTORESEARCH_API_PORT=8000
AUTORESEARCH_API_DB_PATH=/Volumes/PS1008/Github/autonomous-agent-stack/artifacts/api/evaluations.sqlite3

# ===== OpenClaw compat / agent scheduler =====
AUTORESEARCH_CLAUDE_COMMAND=claude
AUTORESEARCH_AGENT_MAX_CONCURRENCY=20
AUTORESEARCH_AGENT_MAX_DEPTH=3

# ===== Tool sandbox (recommended in migration) =====
AUTORESEARCH_TOOL_SANDBOX_BACKEND=docker
AUTORESEARCH_TOOL_SANDBOX_IMAGE=python:3.12-alpine
AUTORESEARCH_TOOL_SANDBOX_CPUS=1.0
AUTORESEARCH_TOOL_SANDBOX_MEMORY=512m
AUTORESEARCH_TOOL_SANDBOX_PIDS_LIMIT=128

# ===== Telegram gateway =====
# Required if you enable /api/v1/gateway/telegram/webhook header validation.
AUTORESEARCH_TELEGRAM_SECRET_TOKEN=<RANDOM_32_PLUS_CHARS_SECRET>
# Telegram bot token for polling bridge / webhook setup
TELEGRAM_BOT_TOKEN=replace_with_your_new_bot_token
# Optional alias for notifier service (if empty, code falls back to TELEGRAM_BOT_TOKEN)
AUTORESEARCH_TELEGRAM_BOT_TOKEN=

# ===== Telegram panel (magic link) =====
# Set a long random secret to enable /status -> panel magic link generation.
AUTORESEARCH_PANEL_JWT_SECRET=replace_with_a_long_random_secret
AUTORESEARCH_PANEL_BASE_URL=http://127.0.0.1:8000/api/v1/panel/view
# Comma-separated Telegram UIDs allowed to open panel.
AUTORESEARCH_TELEGRAM_ALLOWED_UIDS=

# Optional telegram routing knobs
AUTORESEARCH_TELEGRAM_AGENT_NAME=autonomous-agent
AUTORESEARCH_TELEGRAM_GENERATION_DEPTH=1
AUTORESEARCH_TELEGRAM_TIMEOUT_SECONDS=900
AUTORESEARCH_TELEGRAM_WORK_DIR=
AUTORESEARCH_TELEGRAM_CLAUDE_ARGS=
AUTORESEARCH_TELEGRAM_CLAUDE_COMMAND_OVERRIDE=
AUTORESEARCH_TELEGRAM_APPEND_PROMPT=true

# ===== P3 optional =====
AUTORESEARCH_MIROFISH_ENABLED=false
AUTORESEARCH_MIROFISH_MIN_CONFIDENCE=0.35
AUTORESEARCH_MIROFISH_ENGINE=mirofish_heuristic_v1

# ===== Legacy source hints (for migration scripts) =====
OPENCLAW_HOME=/Users/iCloud_GZ/.openclaw
OPENCLAW_MEMORY_REPO=/Volumes/PS1008/Github/openclaw-memory
OPENCLAW_REPO=/Volumes/PS1008/Github/openclaw

"""
Claude API Adapter
统一的 Claude API 调用适配器，提供超时熔断与自动重试保障
"""
import logging
from typing import Dict, Any, Optional
from anthropic import AsyncAnthropic
import asyncio

logger = logging.getLogger(__name__)


class ClaudeAPIAdapter:
    """Claude API 适配器，提供统一的异步调用接口"""
    
    def __init__(self, api_key: Optional[str] = None, default_timeout: float = 60.0):
        self.api_key = api_key
        self.default_timeout = default_timeout
        self._client: Optional[AsyncAnthropic] = None
    
    @property
    def client(self) -> AsyncAnthropic:
        """懒加载 Anthropic 客户端"""
        if self._client is None:
            self._client = AsyncAnthropic(api_key=self.api_key)
        return self._client
    
    async def call(
        self,
        messages: list,
        model: str = "claude-3-5-sonnet-20241022",
        max_tokens: int = 4096,
        temperature: float = 0.7,
        timeout: Optional[float] = None,
        max_retries: int = 3
    ) -> Dict[str, Any]:
        """
        异步调用 Claude API
        
        Args:
            messages: 消息列表
            model: 模型名称
            max_tokens: 最大 token 数
            temperature: 温度参数
            timeout: 超时时间（秒）
            max_retries: 最大重试次数
        
        Returns:
            响应字典，包含 status 和 content/error
        """
        timeout = timeout or self.default_timeout
        
        for attempt in range(max_retries):
            try:
                async with asyncio.timeout(timeout):
                    response = await self.client.messages.create(
                        model=model,
                        max_tokens=max_tokens,
                        temperature=temperature,
                        messages=messages
                    )
                    
                    return {
                        "status": "success",
                        "content": response.content[0].text,
                        "model": response.model,
                        "usage": {
                            "input_tokens": response.usage.input_tokens,
                            "output_tokens": response.usage.output_tokens
                        }
                    }
            
            except asyncio.TimeoutError:
                logger.warning(f"[ClaudeAPI] 超时（尝试 {attempt + 1}/{max_retries}）")
                if attempt == max_retries - 1:
                    return {
                        "status": "error",
                        "error": f"Timeout after {max_retries} retries"
                    }
            
            except Exception as e:
                logger.error(f"[ClaudeAPI] 调用失败: {str(e)}")
                if attempt == max_retries - 1:
                    return {
                        "status": "error",
                        "error": str(e)
                    }
        
        return {
            "status": "error",
            "error": "Max retries exceeded"
        }

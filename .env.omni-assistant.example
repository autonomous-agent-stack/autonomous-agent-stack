# Omni-Assistant Ecosystem Integration Environment Variables
# Copy this file to .env and fill in your credentials

# ============================================================================
# GOOGLE WORKSPACE INTEGRATION
# ============================================================================

# Google OAuth 2.0 Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost

# Google Workspace Scopes (already configured in code)
# - https://www.googleapis.com/auth/calendar
# - https://www.googleapis.com/auth/tasks
# - https://www.googleapis.com/auth/drive.file

# ============================================================================
# APPLE BRIDGE CONFIGURATION
# ============================================================================

# macOS Host Bridge (runs on host, NOT in Docker)
APPLE_BRIDGE_HOST=127.0.0.1
APPLE_BRIDGE_PORT=8765

# Bridge Security
# Only CREATE and READ operations are allowed
# DELETE operations are strictly forbidden

# ============================================================================
# HITL APPROVAL SYSTEM
# ============================================================================

# Default approval timeout (in seconds)
HITL_APPROVAL_TIMEOUT=300

# Telegram TWA Dashboard URL (for approval notifications)
TELEGRAM_TWA_URL=http://localhost:8001/panel

# ============================================================================
# INTERNAL GROUP WHITELIST (from previous security framework)
# ============================================================================

# Comma-separated list of internal group IDs for magic link sharing
AUTORESEARCH_INTERNAL_GROUPS="[-10012345678, -10098765432]"

# JWT Secret for authentication
JWT_SECRET=your-jwt-secret-key-here

# ============================================================================
# SECURITY CONSTRAINTS
# ============================================================================

# Google credentials MUST be loaded from environment
# Apple Bridge MUST run on host (not in Docker)
# DELETE operations are FORBIDDEN
# All cross-ecosystem operations MUST go through HITL approval

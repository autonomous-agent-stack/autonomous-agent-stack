# --- Telegram 物理分流配置 ---
# 注意：超级群组 ID 必须以 -100 开头
AUTORESEARCH_TG_CHAT_ID="<YOUR_TELEGRAM_CHAT_ID>"

# 话题 ID 映射 (Topic IDs)
TG_TOPIC_GENERAL=1
TG_TOPIC_CONTENT=2
TG_TOPIC_SECURITY=3
TG_TOPIC_INTELLIGENCE=4

# --- 安全与审计配置 ---
# 审计日志保留天数
AUDIT_LOG_RETENTION_DAYS=90
# 是否开启 Token 强制脱敏
ENABLE_TOKEN_SANITIZER=true

# --- 宿主机环境优化 ---
# 开启 M1 专用 AppleDouble 自动清理
AUTO_CLEAN_APPLE_DOUBLE=true

# --- Telegram Bot Token (需手动填写) ---
# 请将下面的 your_bot_token_here 替换为您的实际 Bot Token
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# --- 可选配置 ---
# Cloudflare Tunnel 状态检查
# CF_TUNNEL_STATUS=HEALTHY

# --- 说明 ---
# 1. 复制此文件为 .env：cp .env.topic-routing .env
# 2. 编辑 .env 文件，填入您的 TELEGRAM_BOT_TOKEN
# 3. 确认 AUTORESEARCH_TG_CHAT_ID 正确（当前：<YOUR_TELEGRAM_CHAT_ID>）
# 4. 其他配置项可根据需要调整

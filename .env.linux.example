# Linux remote worker example
# Copy the values you actually use into a local .env.linux or ai_lab.env file.
# Do not commit real secrets.

AUTORESEARCH_API_ENV=dev
AUTORESEARCH_API_HOST=0.0.0.0
AUTORESEARCH_API_PORT=8001

AUTORESEARCH_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
AUTORESEARCH_TELEGRAM_ALLOWED_UIDS=123456789
AUTORESEARCH_PANEL_JWT_SECRET=replace-with-random-secret
AUTORESEARCH_PANEL_BASE_URL=http://your-linux-host:8001/api/v1/panel/view
AUTORESEARCH_TELEGRAM_MINI_APP_URL=http://your-linux-host:8001/api/v1/panel/view

OPENHANDS_RUNTIME=host
OPENHANDS_CMD=/home/your-user/.local/bin/openhands
OPENHANDS_BOOTSTRAP_PYTHON=/home/your-user/.local/share/uv/tools/openhands/bin/python

LLM_MODEL=openai/glm-5
LLM_API_KEY=your-glm-api-key
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=
